# GPU Training Server
GPU_HOST=root@your-gpu-server-ip
GPU_KEY=/path/to/your/ssh/key
GPU_REMOTE_DIR=/root/gullyGPT

# Local checkpoint path (used by eval and app)
CHECKPOINT_DIR=checkpoints/qwen-cricket

# LLM Router API keys (referenced in llm_router_config.json)
# Get free keys from:
#   OpenRouter: https://openrouter.ai
#   Gemini:     https://aistudio.google.com
#   Groq:       https://console.groq.com
OPENROUTER_API_KEY=sk-or-v1-YOUR_KEY_HERE
OPENROUTER_API_KEY_SAM=sk-or-v1-YOUR_SECOND_KEY_HERE
GEMINI_API_KEY=AIzaYOUR_KEY_HERE
GROQ_API_KEY=gsk_YOUR_KEY_HERE
GROQ_API_KEY_SAM=gsk_YOUR_SECOND_KEY_HERE
